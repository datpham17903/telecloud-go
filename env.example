# TeleCloud Configuration Example
# Copy this file to .env and fill in your values

# Telegram API credentials (get them from https://my.telegram.org)
API_ID=
API_HASH=


# The Telegram chat/channel ID where files will be stored
# Can be a numeric ID (e.g. -100123456789) or "me" for Saved Messages
LOG_GROUP_ID=me

# Server port
PORT=8091

# Maximum file size allowed for upload (in MB)
# Set to 0 to automatically detect based on your Telegram account (2GB for Normal, 4GB for Premium)
MAX_UPLOAD_SIZE_MB=0

# Database and file storage paths
#DATABASE_PATH=database.db
#THUMBS_DIR=static/thumbs
#TEMP_DIR=./temp
#PROXY_URL= # e.g. socks5://127.0.0.1:1080 or http://127.0.0.1:8080

# FFmpeg path for thumbnail generation. 
# Set to "disabled" to skip video/audio thumbnails if FFmpeg is not installed or causing crashes.
FFMPEG_PATH=ffmpeg
